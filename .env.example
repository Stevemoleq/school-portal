# Local development environment variables
#
# IMPORTANT: This file is committed to the repo as a TEMPLATE only.
# Copy it to .env and fill in real values for your local setup. Production
# deployments must NOT use any of the placeholder values below.

DEBUG=True
# Generate a fresh key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

DB_NAME=school_portal
DB_USER=postgres
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432

# Optional: full DATABASE_URL overrides the DB_* vars when set.
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@nazareneschool.com
